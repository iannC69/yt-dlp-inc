{
  "name": "youtube-downloader-standalone",
  "private": true,
  "description": "MediaDL – YouTube & Spotify downloader desktop app",
  "author": "MediaDL",
  "version": "1.0.49",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "dist:portable": "npm run build && electron-builder --win portable --publish never",
    "dist:installer": "npm run build && electron-builder --win nsis --publish never",
    "release:auto": "node scripts/release.js --installer --bump patch --publish",
    "release": "node scripts/release.js",
    "postinstall": "node scripts/setup-binaries.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "@zaptyp/spotifydl-core": "^0.4.4",
    "archiver": "^8.0.0",
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "node-fetch": "^3.3.2",
    "node-id3": "^0.2.9",
    "puppeteer": "^25.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "spotify-url-info": "^3.3.1",
    "vite": "^8.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "oxlint": "^1.71.0"
  },
  "build": {
    "appId": "com.mediadl.desktop",
    "productName": "MediaDL",
    "copyright": "Copyright © 2024 MediaDL",
    "icon": "installer-assets/app-icon.ico",
    "publish": {
      "provider": "github",
      "owner": "iannC69",
      "repo": "yt-dlp-inc",
      "releaseType": "release"
    },
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist-fe/**/*",
      "electron/**/*",
      "src/server/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MediaDL",
      "uninstallDisplayName": "MediaDL",
      "include": "installer-assets/installer.nsh",
      "installerSidebar": "installer-assets/installer-sidebar.bmp",
      "installerHeader": "installer-assets/installer-header.bmp",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "MediaDL-${version}-portable.exe"
    },
    "artifactName": "MediaDL-Setup-v${version}.${ext}"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true
  }
}
